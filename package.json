{
  "name": "apertus-cli-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test:coverage",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "cli": "npm run start --workspace=@ablunier/apertus-cli"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitest/ui": "^1.3.0",
    "eslint-config-codely": "^4.5.0",
    "tsdown": "^0.2.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  },
  "volta": {
    "node": "24.13.1"
  }
}
